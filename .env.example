# ─── Security ────────────────────────────────────────────────────────
# Required: Must be at least 32 characters long.
# WARNING: Do NOT use these exact placeholder values in production!
FLASK_SECRET_KEY=your_super_secret_flask_key_which_is_long_enough
JWT_SECRET_KEY=your_super_secret_jwt_key_which_is_long_enough
FLASK_ENV=development

# ─── Rate Limiting ────────────────────────────────────────
# Required in production for Flask-Limiter
# REDIS_URL=redis://localhost:6379/0

# ─── Database ─────────────────────────────────────────────
# SQLite (default for development):
DATABASE_URL=sqlite:///deepfake.db
# PostgreSQL (required for production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# ─── File Cleanup ─────────────────────────────────────────
CLEANUP_MAX_AGE_HOURS=24
